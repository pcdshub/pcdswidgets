      <layout class="QVBoxLayout" name="movingIndicatorLayout">
       <item>
        <widget class="PyDMByteIndicator" name="movingIndicator">
      <property name="toolTip">
       <string>Shows motor motion state: stopped or moving.</string>
      </property>
      <property name="whatsThis">
       <string>Byte indicator that reflects motor movement state using BUSY_RBV.</string>
      </property>
      <property name="alarmSensitiveContent" stdset="0">
       <bool>false</bool>
      </property>
      <property name="alarmSensitiveBorder" stdset="0">
       <bool>true</bool>
      </property>
      <property name="channel" stdset="0">
