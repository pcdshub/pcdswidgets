     <item row="1" column="2">
      <widget class="PyDMLineEdit" name="deviceLabel">
       <property name="toolTip">
        <string>Edit the device label directly. Defaults from the base PV name.</string>
       </property>
       <property name="whatsThis">
        <string>This editable field displays the device label from the base PV name and allows direct editing in the screen.</string>
