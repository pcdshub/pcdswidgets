       <item>
        <widget class="PyDMByteIndicator" name="statusIndicator">
      <property name="toolTip">
       <string>Green when all group status PVs are OK; red if any are true.</string>
      </property>
      <property name="whatsThis">
       <string>Combined status indicator for the motor state group.</string>
      </property>
      <property name="alarmSensitiveContent" stdset="0">
       <bool>false</bool>
